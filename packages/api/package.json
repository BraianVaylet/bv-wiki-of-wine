    "db:reset": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@bv/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
