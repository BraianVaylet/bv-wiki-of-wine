# Copiar a .env (NUNCA commitear .env). Ver docs/06-security.md §8.

NODE_ENV=development
# 3100 en dev: bv-my-investments ya usa el 3000 y así corren las dos a la vez.
PORT=3100

# SQLite: un archivo. En Railway apuntar al volumen (/data/wow.db).
DATABASE_PATH=./data/dev.db

# Fotos de etiqueta. En Railway: /data/uploads
UPLOAD_DIR=./data/uploads

# openssl rand -hex 32 — obligatorio y != al default en producción.
SESSION_SECRET=dev-insecure-secret-change-me
SESSION_TTL_DAYS=30
COOKIE_SECURE=false

# Origen del front en dev (en prod se sirve del mismo origen y no aplica).
CORS_ORIGIN=http://localhost:5173

# Registro abierto: apagarlo cuando estén todos adentro. Ver docs/06-security.md §2.
REGISTER_ENABLED=true
MAX_USERS=10
ADMIN_ALIAS=

# Uploads
MAX_UPLOAD_BYTES=6291456
UPLOAD_RATE_LIMIT_MAX=20

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
LOGIN_MAX_ATTEMPTS=8
LOGIN_LOCK_MINUTES=15

LOG_LEVEL=info
